The task specifies FastAPI as the backend framework, not Django. Below is the complete implementation of the `backend/routers/chat_history.py` file for the Chat History domain in a FastAPI application.

```python
from fastapi import APIRouter, Depends, HTTPException, status
from pydantic import BaseModel, Field
from typing import List
from uuid import UUID
from sqlalchemy.orm import Session
from backend.services.chat_history_service import (
    list_chat_sessions,
    create_chat_session,
    get_chat_messages,
)
from database.config import get_db

router = APIRouter()

# Pydantic models for request and response validation
class ChatSessionBase(BaseModel):
    user_id: UUID
    document_id: UUID
    title: str

class ChatSessionResponse(ChatSessionBase):
    id: UUID
    created_at: str
    updated_at: str

class ChatMessageBase(BaseModel):
    session_id: UUID
    role: str
    content: str
    chunk_references: dict

class ChatMessageResponse(ChatMessageBase):
    id: UUID
    created_at: str

# Route: GET /api/chat/sessions
@router.get("/sessions", response_model=List[ChatSessionResponse], status_code=status.HTTP_200_OK)
async def get_chat_sessions(db: Session = Depends(get_db)):
    try:
        sessions = await list_chat_sessions(db)
        return sessions
    except Exception as e:
        raise HTTPException(status_code=status.HTTP_500_INTERNAL_SERVER_ERROR, detail=str(e))

# Route: POST /api/chat/sessions
@router.post("/sessions", response_model=ChatSessionResponse, status_code=status.HTTP_201_CREATED)
async def post_chat_session(session_data: ChatSessionBase, db: Session = Depends(get_db)):
    try:
        new_session = await create_chat_session(session_data, db)
        return new_session
    except Exception as e:
        raise HTTPException(status_code=status.HTTP_500_INTERNAL_SERVER_ERROR, detail=str(e))

# Route: GET /api/chat/sessions/{session_id}/messages
@router.get("/sessions/{session_id}/messages", response_model=List[ChatMessageResponse], status_code=status.HTTP_200_OK)
async def get_messages(session_id: UUID, db: Session = Depends(get_db)):
    try:
        messages = await get_chat_messages(session_id, db)
        return messages
    except Exception as e:
        raise HTTPException(status_code=status.HTTP_500_INTERNAL_SERVER_ERROR, detail=str(e))
```